<%- include('../partials/head') %>
<h2>Админ-панель: пользователи</h2>
<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Админ?</th>
                <th>Дата регистрации</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        <% users.forEach(u => { %>
            <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.is_admin ? 'Да' : 'Нет' %></td>
                <td><%= u.created_at %></td>
                <td>
                    <a href="/admin/users/<%= u.id %>/favorites" class="btn btn-sm btn-info">Избранное</a>
                    <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Удалить пользователя?')">
                        <button class="btn btn-sm btn-danger">Удалить</button>
                    </form>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>