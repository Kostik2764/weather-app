<%- include('../partials/head') %>
<h2>Регистрация</h2>
<% if (typeof error !== 'undefined' && error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<form method="POST" action="/register">
    <div class="mb-3"><input name="username" class="form-control" placeholder="Имя пользователя" required></div>
    <div class="mb-3"><input type="password" name="password" class="form-control" placeholder="Пароль" required></div>
    <button class="btn btn-primary">Зарегистрироваться</button>
</form>
<%- include('../partials/footer') %>